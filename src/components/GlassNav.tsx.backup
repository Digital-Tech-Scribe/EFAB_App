export function GlassNav() {
  const [isOpen, setIsOpen] = useState(false);
  const [scrolled, setScrolled] = useState(false);
  useEffect(() => {
    const handleScroll = () => setScrolled(window.scrollY > 50);
    window.addEventListener('scroll', handleScroll, {
      passive: true
    });
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);
  const handleNavClick = (
    e: React.MouseEvent<HTMLAnchorElement>,
    href: string) =>
  {
    e.preventDefault();
    setIsOpen(false);
    const el = document.querySelector(href);
    if (el) {
      el.scrollIntoView({
        behavior: 'smooth'
      });
    }
  };
  return (
    <>
      {/* Fluid Glass exact header styling */}
      <header
        className="fixed left-1/2 -translate-x-1/2 z-50"
        style={{
          height: '5rem',
          width: '27.6rem',
          bottom: '4rem', // fluid.glass uses bottom: 4rem for desktop
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          color: 'var(--color-white)',
          fontFamily: 'var(--font-f-aeonik-mono)',
          fontSize: '1.2rem',
          fontStyle: 'normal',
          fontWeight: '500',
letterSpacing: '-.02em',
                    lineHeight: '3.6rem',
                    overflow: 'hidden',
                    position: 'relative',
                    willChange: 'color',
                    transition: 'color .5s'
                  }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.color = 'color-mix(in srgb, currentcolor 100%, transparent)';
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.color = 'color-mix(in srgb, currentcolor 60%, transparent)';
                  }}
                >
                  <span>{link.label}</span>
                  {/* Fluid Glass active indicator */}
                  <div className="absolute left-[-2rem] top-1/2 -translate-y-1/2" style={{
                    width: '.6rem',
                    height: '.6rem',
                    backgroundColor: 'currentColor',
                    opacity: index === 0 ? '.6' : '0', // Home is active by default
                    transform: 'rotate(45deg)',
                    transition: 'opacity .25s .5s'
                  }}/>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}
    </>
  );
}